generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Notfall-Datensatz – Server speichert NUR Ciphertext
/// Der Entschlüsselungsschlüssel ist NICHT auf dem Server vorhanden
model EmergencyRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Ciphertext der Notfalldaten (AES-256-GCM, clientseitig verschlüsselt)
  ciphertext String

  /// Initialisierungsvektor (Base64), clientseitig erzeugt
  iv String

  /// Sicherheitsmodus: "direct" (nur QR-Schlüssel) oder "pin" (QR-Schlüssel + PIN via PBKDF2)
  mode String @default("direct")

  /// PBKDF2-Salt (Base64), nur bei mode="pin" gesetzt
  /// Wird für die Schlüsselableitung aus QR-Key + PIN benötigt
  pbkdfSalt String?

  /// Token für die öffentliche Abruf-URL (nicht der Entschlüsselungsschlüssel!)
  /// Dient nur zur Identifikation des Datensatzes
  accessId String @unique

  /// Separates Token für Bearbeitungszugriff (Owner-Beweis)
  /// Wird dem Nutzer bei Erstellung mitgegeben, NIE im QR-Code
  editToken String @unique

  /// Ob der Datensatz aktiv ist (deaktiviert = nicht abrufbar)
  isActive Boolean @default(true)

  /// Öffentlicher Hinweistext (unverschlüsselt, optional)
  /// z.B. "Notfallinformationen hinterlegt" – bewusst KEINE sensiblen Daten
  publicHint String @default("Notfallinformationen hinterlegt")

  /// Zugriffsprotokoll
  accessLogs AccessLog[]

  @@index([accessId])
  @@index([editToken])
}

/// Zugriffsprotokoll für Audit und Missbrauchserkennung
model AccessLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  recordId String
  record   EmergencyRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  /// "view" | "decrypt" | "edit" | "deactivate" | "delete"
  action String

  /// Gehashte IP (DSGVO-konform, nicht rückauflösbar)
  ipHash String

  /// User-Agent (gekürzt)
  userAgent String?

  @@index([recordId])
  @@index([createdAt])
}
